<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/unimart_surface"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingBottom="16dp"
        android:text="@string/profile_photo"
        android:textColor="@color/unimart_text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnChangePhoto"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="start|center_vertical"
        android:paddingHorizontal="24dp"
        android:text="@string/change_photo"
        android:textColor="@color/unimart_text_primary"
        android:textSize="16sp"
        app:icon="@android:drawable/ic_menu_camera"
        app:iconPadding="16dp"
        app:iconTint="@color/unimart_primary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRemovePhoto"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="start|center_vertical"
        android:paddingHorizontal="24dp"
        android:text="@string/remove_photo_label"
        android:textColor="@color/unimart_error"
        android:textSize="16sp"
        app:icon="@android:drawable/ic_menu_delete"
        app:iconPadding="16dp"
        app:iconTint="@color/unimart_error" />

</LinearLayout>
