<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Global Typography System -->
    <style name="TextAppearance.UniMart.ScreenTitle" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/unimart_text_primary</item>
    </style>

    <style name="TextAppearance.UniMart.HomeTitle" parent="TextAppearance.UniMart.ScreenTitle" />

    <style name="TextAppearance.UniMart.SectionTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/unimart_text_primary</item>
    </style>

    <style name="TextAppearance.UniMart.ProductName" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/unimart_text_primary</item>
    </style>

    <style name="TextAppearance.UniMart.Price" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/unimart_primary</item>
    </style>

    <style name="TextAppearance.UniMart.Description" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/unimart_text_secondary</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <!-- Global Component Styles -->
    <style name="Widget.UniMart.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/btn_height</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/unimart_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/radius_premium</item>
        <item name="rippleColor">#33FFFFFF</item>
    </style>

    <style name="Widget.UniMart.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/unimart_surface</item>
        <item name="cardCornerRadius">@dimen/radius_premium</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="strokeWidth">0dp</item>
        <item name="android:stateListAnimator">@animator/card_state_animator</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="Widget.UniMart.PremiumCard" parent="Widget.UniMart.Card" />

    <style name="Widget.UniMart.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/unimart_surface</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_premium</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_premium</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_premium</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_premium</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxStrokeColor">@color/unimart_primary</item>
        <item name="hintTextColor">@color/unimart_text_secondary</item>
        <item name="android:textColorHint">@color/unimart_text_secondary</item>
    </style>

    <style name="Widget.UniMart.SearchLayout" parent="Widget.UniMart.TextInputLayout">
        <item name="boxCornerRadiusTopStart">@dimen/radius_search</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_search</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_search</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_search</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="startIconTint">@color/unimart_primary</item>
    </style>

    <style name="Widget.UniMart.TextInputEditText" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@color/unimart_text_primary</item>
        <item name="android:padding">16dp</item>
        <item name="android:background">@null</item>
        <item name="android:textColorHint">@color/unimart_text_secondary</item>
    </style>

    <style name="Widget.UniMart.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="background">@color/unimart_background</item>
        <item name="titleTextColor">@color/white</item>
        <item name="navigationIconTint">@color/white</item>
        <item name="titleCentered">true</item>
    </style>

    <style name="Widget.UniMart.Chip" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">@color/unimart_surface_elevated</item>
        <item name="android:textColor">@color/unimart_primary</item>
        <item name="chipIconTint">@color/unimart_primary</item>
        <item name="chipCornerRadius">@dimen/radius_medium</item>
        <item name="chipStrokeWidth">0dp</item>
    </style>

    <style name="Widget.UniMart.FAB" parent="Widget.Material3.ExtendedFloatingActionButton.Primary">
        <item name="backgroundTint">@color/unimart_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="iconTint">@color/white</item>
        <item name="cornerRadius">@dimen/radius_premium</item>
    </style>

    <style name="Widget.UniMart.SellFAB" parent="Widget.UniMart.FAB" />

    <style name="Widget.UniMart.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/unimart_bottom_nav</item>
        <item name="itemIconTint">@color/unimart_nav_selector</item>
        <item name="itemTextColor">@color/unimart_nav_selector</item>
        <item name="itemRippleColor">#22FFFFFF</item>
    </style>

    <style name="Widget.UniMart.BottomNavigationView" parent="Widget.UniMart.BottomNav" />

    <!-- Centralized Popup Overlay (Fixes Background & Text Color) -->
    <style name="ThemeOverlay.UniMart.Popup" parent="ThemeOverlay.Material3.AutoCompleteTextView">
        <item name="colorSurface">@color/unimart_surface_elevated</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
    </style>

</resources>
