<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- UniMart Global Design System (Material 3) -->
    <style name="Base.Theme.UniMart" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Palette -->
        <item name="colorPrimary">@color/unimart_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/unimart_background</item>
        <item name="colorSurface">@color/unimart_surface</item>
        <item name="colorOnSurface">@color/unimart_text_primary</item>
        <item name="colorSurfaceVariant">@color/unimart_surface_elevated</item>
        <item name="colorOnSurfaceVariant">@color/unimart_text_secondary</item>
        <item name="colorError">@color/unimart_error</item>

        <!-- Global Component Styles -->
        <item name="materialCardViewStyle">@style/Widget.UniMart.Card</item>
        <item name="materialButtonStyle">@style/Widget.UniMart.Button</item>
        <item name="textInputStyle">@style/Widget.UniMart.TextInputLayout</item>
        <item name="chipStyle">@style/Widget.UniMart.Chip</item>
        <item name="bottomNavigationStyle">@style/Widget.UniMart.BottomNav</item>
        <item name="extendedFloatingActionButtonStyle">@style/Widget.UniMart.FAB</item>
        <item name="toolbarStyle">@style/Widget.UniMart.Toolbar</item>

        <!-- Popup Menu & Dropdown Styles (Centralized Fix) -->
        <item name="actionBarPopupTheme">@style/ThemeOverlay.UniMart.Popup</item>
        <item name="popupTheme">@style/ThemeOverlay.UniMart.Popup</item>

        <!-- System Bars -->
        <item name="android:statusBarColor">@color/unimart_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/unimart_bottom_nav</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
    </style>

    <style name="Theme.UniMart" parent="Base.Theme.UniMart" />
</resources>
